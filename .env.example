# ═══════════════════════════════════════════════════════════════
# Nyx — Security Dashboard Configuration
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./data/nyx.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://nyx:password@localhost:5432/nyx

# ─── GitHub ──────────────────────────────────────────────────────
# Personal Access Token with scopes: repo, admin:repo_hook, security_events
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# The public URL of your Nyx backend (used for webhook registration)
# Must be reachable by GitHub's servers.
GITHUB_WEBHOOK_ENDPOINT=https://your-nyx-instance.example.com/api/v1/webhooks/github

# ─── GitHub Code Scanning Auto-Sync ──────────────────────────────
# When enabled, Nyx polls the GitHub Code Scanning API for all
# registered repositories and imports open alerts automatically.
# Requires GITHUB_TOKEN with the `security_events` scope.
CODE_SCANNING_SYNC_ENABLED=false
CODE_SCANNING_POLL_INTERVAL=3600

# ─── Anthropic / Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# ─── Jira ────────────────────────────────────────────────────────
# For real Jira: set JIRA_MOCK_MODE=false and fill in the other four.
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://mycompany.atlassian.net
JIRA_USER_EMAIL=me@example.com
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT_KEY=SEC
JIRA_ISSUE_TYPE=Bug
JIRA_MOCK_MODE=false

# ─── Snyk ────────────────────────────────────────────────────────
# Secret set in Snyk → Settings → Integrations → Webhooks.
# Leave blank to skip signature verification (dev only).
SNYK_WEBHOOK_SECRET=

# ─── Nyx Authentication ──────────────────────────────────────────
# Master API key for the dashboard UI and CI/CD integration.
# Leave blank to disable authentication (development only).
NYX_API_KEY=nyx-your-secret-key-here

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# ─── Scanner Defaults ────────────────────────────────────────────
# Scanners enabled by default when a new repository is registered.
DEFAULT_ENABLED_SCANNERS_STR=SEMGREP,BANDIT,TRIVY,GRYPE,CHECKOV

# ─── SLA Targets (days) ──────────────────────────────────────────
SLA_CRITICAL_DAYS=7
SLA_HIGH_DAYS=30
SLA_MEDIUM_DAYS=90
SLA_LOW_DAYS=180

# ─── EPSS Integration ────────────────────────────────────────────
# Exploit Prediction Scoring System — enriches CVE findings with
# real-world exploit likelihood scores from first.org.
EPSS_API_ENABLED=true

# ─── Notifications ───────────────────────────────────────────────
# Slack-compatible outbound webhook URL for critical finding alerts.
# Leave blank to disable.
NOTIFICATION_WEBHOOK_URL=

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Development ─────────────────────────────────────────────────
DEBUG=false
