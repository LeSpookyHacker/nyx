# ═══════════════════════════════════════════════════════════════
# Nyx — Security Dashboard Configuration
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./data/nyx.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://nyx:password@localhost:5432/nyx

# ─── GitHub ──────────────────────────────────────────────────────
# Personal Access Token with scopes: repo, admin:repo_hook, security_events
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# The public URL of your Nyx backend — used when registering GitHub webhooks.
# Must be reachable by GitHub's servers.
# ⚠️  Must include the FULL PATH — Nyx uses this value verbatim, no path is appended.
# ⚠️  After changing this value, restart with `docker compose up -d` (not `restart`).
#     `docker compose restart` does NOT re-read .env; `up -d` recreates the containers.
# Local dev: use ngrok → `ngrok http 8000` (port 8000, NOT 3000 or 80)
#            then set to https://<id>.ngrok-free.app/api/v1/webhooks/github
GITHUB_WEBHOOK_ENDPOINT=https://your-nyx-instance.example.com/api/v1/webhooks/github

# ─── GitHub Code Scanning Auto-Sync ──────────────────────────────
# When enabled, Nyx polls the GitHub Code Scanning API for all
# registered repositories and imports open alerts automatically.
# Requires GITHUB_TOKEN with the `security_events` scope.
CODE_SCANNING_SYNC_ENABLED=false
CODE_SCANNING_POLL_INTERVAL=3600

# ─── Anthropic / Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
# Maximum *output* tokens for AI fix generation (the Claude API max_tokens param is output-only).
AI_MAX_OUTPUT_TOKENS=8192
# Per-call timeout in seconds for Anthropic API requests.
ANTHROPIC_TIMEOUT=90.0
# Fixes with confidence below this threshold are flagged in REVIEW_LOW_CONFIDENCE status.
AI_MIN_CONFIDENCE_THRESHOLD=0.4

# ─── Jira ────────────────────────────────────────────────────────
# For real Jira: set JIRA_MOCK_MODE=false and fill in the other four.
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://mycompany.atlassian.net
JIRA_USER_EMAIL=me@example.com
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT_KEY=SEC
JIRA_ISSUE_TYPE=Bug
JIRA_MOCK_MODE=false

# ─── Snyk ────────────────────────────────────────────────────────
# Secret set in Snyk → Settings → Integrations → Webhooks.
# Leave blank to skip signature verification (dev only).
SNYK_WEBHOOK_SECRET=

# ─── Nyx Authentication ──────────────────────────────────────────
# Master API key for the dashboard UI and CI/CD integration.
# Leave blank to disable authentication (development only).
# SEC-243: replaced guessable placeholder — generate a real key before deploying.
# Generate: python -c "import secrets; print('nyx-' + secrets.token_hex(32))"
# ⚠️  The bootstrap key printed by setup.sh is ADMIN-scoped.
#     Do NOT use it in GitHub Actions / CI. Instead, go to Nyx Settings → API Keys
#     and create a SCANNER-scoped key for each repository's CI pipeline.
NYX_API_KEY=

# ─── Secret key for at-rest encryption and audit HMAC chain ─────
# Used for encrypting secrets at rest and maintaining the audit log HMAC chain.
# Required for audit integrity — changing this value will break the HMAC chain
# and make it impossible to verify historical audit entries.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NYX_SECRET_KEY=

# ─── Global webhook HMAC pre-check (optional, production hardening) ─────────
# If set, ALL GitHub webhook payloads must carry a matching X-Hub-Signature-256.
# ⚠️  Leave EMPTY for the standard setup — Nyx uses per-repo secrets automatically.
#     Setting this breaks all webhook deliveries unless you've also configured the
#     same value in every GitHub webhook config manually.
# Only set this if you want an additional defence-in-depth layer against repo
# enumeration attacks in a high-security production environment. Not required for
# webhooks to work — per-repo secrets (auto-generated on repo add) handle auth.
# ⚠️  NAME COLLISION: In GitHub Actions secrets, NYX_WEBHOOK_SECRET means the
#     PER-REPO secret (get it from Nyx: Repositories → [repo] → Reveal button).
#     That is NOT the same as this global .env variable. See wiki/CICD-Integration.md.
NYX_WEBHOOK_SECRET=

# ─── API key maximum lifetime ───────────────────────────────────
# Maximum lifetime for new API keys in days. 0 = no limit.
API_KEY_MAX_LIFETIME_DAYS=0

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# ─── Scanner Defaults ────────────────────────────────────────────
# Scanners enabled by default when a new repository is registered.
DEFAULT_ENABLED_SCANNERS_STR=SEMGREP,BANDIT,TRIVY,GRYPE,CHECKOV

# ─── SLA Targets (days) ──────────────────────────────────────────
SLA_CRITICAL_DAYS=7
SLA_HIGH_DAYS=30
SLA_MEDIUM_DAYS=90
SLA_LOW_DAYS=180

# ─── EPSS Integration ────────────────────────────────────────────
# Exploit Prediction Scoring System — enriches CVE findings with
# real-world exploit likelihood scores from first.org.
EPSS_API_ENABLED=true

# ─── Notifications ───────────────────────────────────────────────
# Slack-compatible outbound webhook URL for critical finding alerts.
# Leave blank to disable.
NOTIFICATION_WEBHOOK_URL=

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Development ─────────────────────────────────────────────────
DEBUG=false
